DATABASE_URI=postgresql://user:password@host/dbname?sslmode=require
PAYLOAD_SECRET=generate-with-openssl-rand-hex-32
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yourdomain.com

# AWS SES — used by /contact form to send inquiries.
# IAM user needs ses:SendEmail permission only.
# Sender (mail@expressfoodsco.com) and recipient (info@expressfoodsco.com)
# must be verified in SES while account is in sandbox.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA_REPLACE_ME
AWS_SECRET_ACCESS_KEY=replace_me
